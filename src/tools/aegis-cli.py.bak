#!/usr/bin/env python3
"""
Aegis Orchestrator CLI v3.0 — Wellton Photonics
OODA-native. NDGi-aware. TDD-gated. Loop-proof.

Every action runs through:
  OBSERVE  → scan workspace + NDGi graph + file existence
  ORIENT   → classify intent, check what's already done
  DECIDE   → plan action or reject if already complete / looping
  ACT      → execute with pre/post verification

Merged: Oakland CLI (MCP, typo correction) + Aegis v2 (BitNet, FILE ops, shell)
"""

import os, sys, re, json, time, subprocess, importlib.util, hashlib
from pathlib import Path

# ── Config ────────────────────────────────────────────────────────────────────
API_URL            = "http://localhost:8080/completion"
NDGI_BASE          = "http://localhost:8000"
SYSTEM_PROMPT_FILE = "aegis_system_prompt.txt"
MAX_HISTORY_TURNS  = 10
MAX_IDENTICAL_RESPONSES = 2          # loop detection threshold
WORKSPACE_ROOT     = os.path.expanduser("~/workspace/aegis-ternary")
SRC_ROOT           = os.path.join(WORKSPACE_ROOT,
                                  "src/wp1-lab/wp1-experience/src")
LOG_DIR            = os.path.join(WORKSPACE_ROOT, "docs/workon/runner_logs")
NDGI_SESSION_FILE  = os.path.join(LOG_DIR, "ndgi_session.json")

# ── ANSI ──────────────────────────────────────────────────────────────────────
CY="\033[1;36m"; GR="\033[1;32m"; YL="\033[1;33m"
RD="\033[1;31m"; BL="\033[1;34m"; DM="\033[0;36m"; RS="\033[0m"

# ══════════════════════════════════════════════════════════════════════════════
# NDGi SESSION GRAPH
# In-memory graph of everything done this session.
# Persisted to NDGI_SESSION_FILE between runs.
# ══════════════════════════════════════════════════════════════════════════════
class NDGiSession:
    def __init__(self):
        self.nodes = {}   # path → {trit, hash, op, ts, attempts}
        self.load()

    def load(self):
        try:
            os.makedirs(LOG_DIR, exist_ok=True)
            if os.path.exists(NDGI_SESSION_FILE):
                self.nodes = json.load(open(NDGI_SESSION_FILE))
        except:
            self.nodes = {}

    def save(self):
        try:
            json.dump(self.nodes, open(NDGI_SESSION_FILE, "w"), indent=2)
        except:
            pass

    def register(self, path, trit, op, content=""):
        h = hashlib.md5(content.encode()).hexdigest()[:8] if content else ""
        self.nodes[path] = {
            "trit": trit, "hash": h, "op": op,
            "ts": time.strftime("%Y-%m-%d %H:%M:%S"),
            "attempts": self.nodes.get(path, {}).get("attempts", 0) + 1
        }
        self.save()

    def get(self, path):
        return self.nodes.get(path)

    def is_done(self, path):
        n = self.get(path)
        return n and n["trit"] == 1

    def attempts(self, path):
        n = self.get(path)
        return n["attempts"] if n else 0

    def summary(self):
        done  = [p for p,n in self.nodes.items() if n["trit"]==1]
        pend  = [p for p,n in self.nodes.items() if n["trit"]==0]
        fail  = [p for p,n in self.nodes.items() if n["trit"]==-1]
        return done, pend, fail

    def print_graph(self):
        done, pend, fail = self.summary()
        print(f"\n{CY}NDGi SESSION GRAPH{RS}")
        print(f"  {GR}TRIT_POS  ({len(done)}){RS}")
        for p in done:
            n = self.nodes[p]
            print(f"    ✓ {os.path.relpath(p, WORKSPACE_ROOT)}  [{n['ts']}]")
        if pend:
            print(f"  {YL}TRIT_ZERO ({len(pend)}){RS}")
            for p in pend:
                print(f"    ○ {os.path.relpath(p, WORKSPACE_ROOT)}")
        if fail:
            print(f"  {RD}TRIT_NEG  ({len(fail)}){RS}")
            for p in fail:
                n = self.nodes[p]
                print(f"    ✗ {os.path.relpath(p, WORKSPACE_ROOT)}  [attempts:{n['attempts']}]")
        print()

# ══════════════════════════════════════════════════════════════════════════════
# OODA ENGINE
# Runs before every prompt reaches BitNet.
# ══════════════════════════════════════════════════════════════════════════════
class OODAEngine:
    def __init__(self, ndgi: NDGiSession):
        self.ndgi    = ndgi
        self.history = []   # response hashes for loop detection

    # ── OBSERVE ───────────────────────────────────────────────────────────────
    def observe(self, user_input: str) -> dict:
        """Scan environment. Return context dict."""
        ctx = {
            "input":       user_input,
            "intent":      None,
            "files_mentioned": [],
            "files_exist": {},
            "files_done":  {},
            "workspace_writable": os.access(WORKSPACE_ROOT, os.W_OK),
            "bitnet_up":   self._check_port(8080),
            "ndgi_up":     self._check_port(8000),
        }
        # Extract file paths from input
        paths = re.findall(r'(/[\w/.\-]+\.\w+)', user_input)
        for p in paths:
            ctx["files_mentioned"].append(p)
            ctx["files_exist"][p]  = os.path.exists(p)
            ctx["files_done"][p]   = self.ndgi.is_done(p)
        return ctx

    # ── ORIENT ────────────────────────────────────────────────────────────────
    def orient(self, ctx: dict) -> dict:
        """Classify intent. Detect what can be skipped."""
        inp = ctx["input"].lower()

        # Intent classification
        if any(w in inp for w in ("what time","time is it","what's the time")):
            ctx["intent"] = "local_time"
        elif any(w in inp for w in ("status","health","online","offline")):
            ctx["intent"] = "status"
        elif any(w in inp for w in ("help","commands")):
            ctx["intent"] = "help"
        elif any(w in inp for w in ("history",)):
            ctx["intent"] = "history"
        elif any(w in inp for w in ("graph","ndgi graph","what's been done","show graph")):
            ctx["intent"] = "graph"
        elif "<<<<<<< create" in inp or "<<<<<<< replace" in inp or \
             inp.startswith("file:"):
            ctx["intent"] = "file_op"
        elif any(w in inp for w in ("create","write","build","make","generate",
                                     "add","fix","patch","update")):
            ctx["intent"] = "code_task"
        else:
            ctx["intent"] = "conversation"

        # Skip detection — files already done
        ctx["skip_files"] = [
            p for p in ctx["files_mentioned"]
            if ctx["files_done"].get(p) and ctx["files_exist"].get(p)
        ]

        # Attempt guard — if file tried 3+ times, flag it
        ctx["stuck_files"] = [
            p for p in ctx["files_mentioned"]
            if self.ndgi.attempts(p) >= 3
        ]

        return ctx

    # ── DECIDE ────────────────────────────────────────────────────────────────
    def decide(self, ctx: dict) -> dict:
        """Choose action. Block if already done or stuck."""
        ctx["action"] = "engine"   # default: send to BitNet

        if ctx["intent"] in ("local_time","status","help","history",
                             "graph","local_shell"):
            ctx["action"] = ctx["intent"]
            return ctx

        if ctx["intent"] == "conversation":
            ctx["action"] = "engine"
            return ctx

        # File already done + exists → skip
        if ctx["skip_files"]:
            ctx["action"] = "skip"
            ctx["skip_reason"] = (
                f"Already completed: "
                + ", ".join(os.path.basename(p) for p in ctx["skip_files"])
                + ". Use 'force' keyword to overwrite."
            )
            return ctx

        # Stuck file → warn before sending
        if ctx["stuck_files"]:
            ctx["action"] = "warn_stuck"

        # Engine not up
        if ctx["intent"] in ("file_op","code_task") and not ctx["bitnet_up"]:
            ctx["action"] = "engine_offline"

        return ctx

    # ── ACT (pre-check) ───────────────────────────────────────────────────────
    def pre_act_report(self, ctx: dict) -> str | None:
        """
        Returns a string to print before sending to engine, or None.
        Returns False to block the engine call entirely.
        """
        action = ctx["action"]

        if action == "skip":
            return f"{YL}[OODA/DECIDE]{RS} {ctx['skip_reason']}"

        if action == "engine_offline":
            return (f"{RD}[OODA/OBSERVE]{RS} BitNet b1.58 is offline.\n"
                    f"  {YL}→ cd ~/BitNet && "
                    f"./llama-server -m models/ggml-model-i2_s.gguf --port 8080{RS}")

        if action == "warn_stuck":
            files = ", ".join(os.path.basename(p) for p in ctx["stuck_files"])
            return (f"{YL}[OODA/ORIENT]{RS} Warning: {files} has failed "
                    f"{self.ndgi.attempts(ctx['stuck_files'][0])}× already.\n"
                    f"  Sending to engine anyway. Consider 'cat' to inspect first.")

        if ctx["files_mentioned"]:
            lines = [f"{DM}[OODA/OBSERVE]{RS} Environment scan:"]
            for p in ctx["files_mentioned"]:
                exists = ctx["files_exist"].get(p)
                done   = ctx["files_done"].get(p)
                state  = (f"{GR}exists+done{RS}" if exists and done
                          else f"{YL}exists{RS}" if exists
                          else f"{DM}not found{RS}")
                lines.append(f"  {p} → {state}")
            return "\n".join(lines)

        return None

    def _check_port(self, port):
        import socket
        try:
            s = socket.create_connection(("localhost", port), timeout=1)
            s.close()
            return True
        except:
            return False

    # ── Loop detection ────────────────────────────────────────────────────────
    def is_looping(self, response: str) -> bool:
        h = hashlib.md5(response[:200].encode()).hexdigest()
        self.history.append(h)
        if len(self.history) > MAX_IDENTICAL_RESPONSES:
            self.history = self.history[-MAX_IDENTICAL_RESPONSES:]
        return len(self.history) == MAX_IDENTICAL_RESPONSES and \
               len(set(self.history)) == 1

# ══════════════════════════════════════════════════════════════════════════════
# SYSTEM PROMPT
# ══════════════════════════════════════════════════════════════════════════════
DEFAULT_SYSTEM = (
    "You are PHOTNX, the Aegis Orchestrator for Wellton Photonics.\n"
    "Engineering AI assistant. PSTLA: least action, no unnecessary abstraction.\n\n"
    "BEFORE every file action you MUST:\n"
    "1. State what file you are about to write and why.\n"
    "2. Confirm the file does not already exist with correct content.\n"
    "3. Write real working code — never placeholders, never 'content goes here'.\n"
    "4. Close every FILE block with >>>>>>> END or >>>>>>> REPLACE.\n"
    "5. End with one trit: TRIT_POS / TRIT_ZERO / TRIT_NEG.\n\n"
    "RESPONSE RULES:\n"
    "- Conversational question → plain English answer, no FILE block.\n"
    "- Time/date → answer in English. Example: 'It is 6:09 PM.'\n"
    "- Code task → one FILE block per file, real code, close the block.\n"
    "- Never loop. If you already wrote a file, say so and stop.\n"
    "- Never wrap responses in markdown ``` fences — emit raw code in FILE blocks.\n\n"
    "FILE CREATE (new file):\n"
    "FILE: /absolute/path/file.ext\n"
    "<<<<<<< CREATE\n"
    "[complete working code]\n"
    ">>>>>>> END\n"
    "TRIT_POS\n\n"
    "FILE REPLACE (patch existing):\n"
    "FILE: /absolute/path/file.ext\n"
    "<<<<<<< SEARCH\n"
    "[exact lines]\n"
    "=======\n"
    "[replacement]\n"
    ">>>>>>> REPLACE\n"
    "TRIT_POS\n\n"
    "Stop tokens: <|end|> <|im_end|> — stop generating when you reach these."
)

def load_system_prompt():
    if os.path.exists(SYSTEM_PROMPT_FILE):
        return open(SYSTEM_PROMPT_FILE).read().strip()
    return DEFAULT_SYSTEM

# ══════════════════════════════════════════════════════════════════════════════
# FILE EDITOR (with TDD pre/post checks)
# ══════════════════════════════════════════════════════════════════════════════
def resolve_path(raw):
    p = os.path.expanduser(raw.strip())
    return p if os.path.isabs(p) else os.path.join(WORKSPACE_ROOT, p)

def fuzzy_find(content, search):
    idx = content.find(search)
    if idx != -1:
        return idx
    def norm(t): return "\n".join(l.rstrip() for l in t.splitlines())
    nc, ns = norm(content), norm(search)
    idx = nc.find(ns)
    if idx != -1:
        tgt   = nc[:idx].count("\n")
        lines = content.splitlines(keepends=True)
        start = sum(len(l) for l in lines[:tgt])
        end   = sum(len(l) for l in lines[:tgt + ns.count("\n") + 1])
        return (start, end)
    return -1

def tdd_check(path, content):
    """Basic TDD post-write checks. Returns list of warnings."""
    warnings = []
    if not content.strip():
        warnings.append("EMPTY FILE")
    if "content goes here" in content.lower():
        warnings.append("PLACEHOLDER DETECTED")
    if "all lines of content" in content.lower():
        warnings.append("PLACEHOLDER DETECTED")
    if path.endswith(".jsx") or path.endswith(".js"):
        if "export" not in content and "module.exports" not in content:
            warnings.append("NO EXPORT FOUND")
        if content.count("{") != content.count("}"):
            warnings.append(f"BRACE MISMATCH {content.count('{')}/{content.count('}')}")
    if path.endswith(".py"):
        if content.count("def ") == 0 and content.count("class ") == 0 and \
           not content.strip().startswith("#"):
            warnings.append("NO FUNCTION/CLASS FOUND")
    return warnings

def apply_all_edits(text, ndgi: NDGiSession, force=False):
    results = []

    for m in re.finditer(
            r"FILE:\s*(.+?)\n<<<<<<< CREATE\n(.*?)\n>>>>>>> END",
            text, re.DOTALL):
        path    = resolve_path(m.group(1))
        content = m.group(2)

        print(f"\n{YL}[OODA/ACT — CREATE]{RS} {path}")

        # TDD pre-check: already exists?
        if os.path.exists(path) and not force:
            existing = open(path).read()
            if "content goes here" not in existing.lower() and \
               len(existing.strip()) > 20:
                print(f"{YL}[TDD]{RS} File exists with real content — skipping.")
                print(f"  Use 'force' keyword to overwrite.")
                ndgi.register(path, 1, "create-skipped", existing)
                results.append({"ok": True, "op": "skip", "path": path})
                continue

        # TDD content check before writing
        warnings = tdd_check(path, content)
        if warnings:
            print(f"{RD}[TDD FAIL]{RS} {', '.join(warnings)}")
            print(f"  Refusing to write placeholder content to {path}")
            ndgi.register(path, -1, "create-tdd-fail", content)
            results.append({"ok": False, "op": "create", "path": path,
                             "err": "tdd_fail: " + ", ".join(warnings)})
            continue

        try:
            os.makedirs(os.path.dirname(path), exist_ok=True)
            open(path, "w").write(content)
            # TDD post-write verify
            written = open(path).read()
            post_warn = tdd_check(path, written)
            if post_warn:
                print(f"{RD}[TDD POST-FAIL]{RS} {', '.join(post_warn)}")
                ndgi.register(path, -1, "create-post-tdd-fail", content)
                results.append({"ok": False, "op": "create", "path": path,
                                 "err": "post_tdd: " + ", ".join(post_warn)})
            else:
                print(f"{GR}[TRIT_POS]{RS} {os.path.basename(path)} "
                      f"written ({len(content)} chars)")
                ndgi.register(path, 1, "create", content)
                results.append({"ok": True, "op": "create", "path": path})
        except Exception as e:
            print(f"{RD}[TRIT_NEG]{RS} {e}")
            ndgi.register(path, -1, "create-error", "")
            results.append({"ok": False, "op": "create", "path": path,
                             "err": str(e)})

    for m in re.finditer(
            r"FILE:\s*(.+?)\n<<<<<<< SEARCH\n(.*?)\n=======\n(.*?)\n>>>>>>> REPLACE",
            text, re.DOTALL):
        path    = resolve_path(m.group(1))
        search  = m.group(2)
        replace = m.group(3)

        print(f"\n{YL}[OODA/ACT — REPLACE]{RS} {path}")

        warnings = tdd_check(path, replace)
        if warnings:
            print(f"{RD}[TDD FAIL]{RS} {', '.join(warnings)} — not writing")
            ndgi.register(path, -1, "replace-tdd-fail", replace)
            results.append({"ok": False, "op": "replace", "path": path,
                             "err": "tdd_fail"})
            continue

        os.makedirs(os.path.dirname(path), exist_ok=True)

        if not os.path.exists(path):
            open(path, "w").write(replace)
            print(f"{GR}[TRIT_POS]{RS} created from replace block")
            ndgi.register(path, 1, "replace-create", replace)
            results.append({"ok": True, "op": "replace", "path": path})
            continue

        orig  = open(path).read()
        match = fuzzy_find(orig, search)
        if match == -1:
            print(f"{RD}[TRIT_NEG]{RS} search block not matched in {path}")
            print(f"  {YL}→ cat {path}{RS}  to inspect")
            ndgi.register(path, -1, "replace-no-match", "")
            results.append({"ok": False, "op": "replace", "path": path,
                             "err": "no_match"})
            continue

        updated = (orig[:match[0]] + replace + orig[match[1]:]
                   if isinstance(match, tuple)
                   else orig.replace(search, replace, 1))
        open(path, "w").write(updated)
        print(f"{GR}[TRIT_POS]{RS} {os.path.basename(path)} patched")
        ndgi.register(path, 1, "replace", replace)
        results.append({"ok": True, "op": "replace", "path": path})

    return results

# ══════════════════════════════════════════════════════════════════════════════
# BITNET QUERY
# ══════════════════════════════════════════════════════════════════════════════
def query_engine(system, history, user_input, ndgi, ooda):
    # Build workspace context to inject
    done, pend, fail = ndgi.summary()
    ws_ctx = ""
    if done:
        ws_ctx += "FILES COMPLETED THIS SESSION:\n"
        ws_ctx += "\n".join(f"  ✓ {os.path.relpath(p,WORKSPACE_ROOT)}"
                            for p in done) + "\n"
    if fail:
        ws_ctx += "FILES FAILED (do not retry without inspection):\n"
        ws_ctx += "\n".join(f"  ✗ {os.path.relpath(p,WORKSPACE_ROOT)}"
                            for p in fail) + "\n"

    context = ""
    for t in history[-MAX_HISTORY_TURNS:]:
        context += f"<|user|>\n{t['user']}\n<|assistant|>\n{t['assistant']}\n"

    full_system = system
    if ws_ctx:
        full_system = system + f"\n\nSESSION STATE:\n{ws_ctx}"

    prompt = (
        f"<|system|>\n{full_system}\n"
        f"{context}"
        f"<|user|>\n{user_input}\n<|assistant|>\n"
    )

    payload = {
        "prompt":         prompt,
        "n_predict":      2048,
        "temperature":    0.15,
        "repeat_penalty": 1.35,
        "stop":           ["<|user|>", "<|system|>", "<|end|>", "<|im_end|>"],
        "stream":         True
    }

    sys.stdout.write(f"\n{CY}Aegis-PHOTNX:{RS} ")
    sys.stdout.flush()

    accumulated = ""
    try:
        import requests
        r = requests.post(API_URL, json=payload,
                          headers={"Content-Type": "application/json"},
                          stream=True, timeout=180)
        r.raise_for_status()
        for line in r.iter_lines():
            if not line: continue
            s = line.decode("utf-8")
            if s.startswith("data: "): s = s[6:]
            try:
                d   = json.loads(s)
                tok = d.get("content", "")
                accumulated += tok
                sys.stdout.write(tok)
                sys.stdout.flush()
                if d.get("stop"): break
            except json.JSONDecodeError:
                continue
    except Exception as e:
        print(f"\n{RD}[Error]{RS} {e}")
        return ""

    print("\n")

    # Loop detection
    if ooda.is_looping(accumulated):
        print(f"{RD}[OODA/OBSERVE]{RS} Loop detected — same response twice.")
        print(f"  {YL}Halting. Rephrase your prompt or use a direct shell command.{RS}\n")
        return ""

    # Apply edits with TDD
    force = "force" in user_input.lower()
    edits = apply_all_edits(accumulated, ndgi, force=force)

    ok  = sum(1 for e in edits if e["ok"])
    bad = len(edits) - ok
    if edits:
        summary = f"\n[Session: {ok} written, {bad} failed]"
        print(f"{DM}{summary}{RS}")
        accumulated += summary

    _log(user_input, accumulated)
    return accumulated

# ══════════════════════════════════════════════════════════════════════════════
# LOCAL COMMANDS + SPLASH + HELP
# ══════════════════════════════════════════════════════════════════════════════
def load_mcp_agent():
    mcp_path = Path("/home/jsosa/workspace/aegis-ternary/src/updates/mcp_response_agent.py")
    if not mcp_path.exists(): return None
    try:
        spec = importlib.util.spec_from_file_location("mcp_agent", mcp_path)
        mod  = importlib.util.module_from_spec(spec)
        spec.loader.exec_module(mod)
        return mod.MCPResponseAgent()
    except Exception as e:
        print(f"{YL}[Oakland]: {e}{RS}")
        return None

