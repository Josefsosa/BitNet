    print(f"""{CY}
    ██████╗ ██╗  ██╗ ██████╗ ████████╗███╗  ██╗██╗  ██╗
    ██╔══██╗██║  ██║██╔═══██╗╚══██╔══╝████╗ ██║╚██╗██╔╝
    ██████╔╝███████║██║   ██║   ██║   ██╔██╗██║ ╚███╔╝
    ██╔═══╝ ██╔══██║██║   ██║   ██║   ██║╚████║ ██╔██╗
    ██║     ██║  ██║╚██████╔╝   ██║   ██║ ╚███║██╔╝╚██╗
    ╚═╝     ╚═╝  ╚═╝ ╚═════╝    ╚═╝   ╚═╝  ╚══╝╚═╝  ╚═╝{RS}
{DM}
    ┌────────────────────────────────────────────────────────┐
    │   AEGIS ORCHESTRATOR v3.0  ·  OODA-Native · NDGi-Live │
    │   BitNet b1.58  ·  TDD-Gated  ·  Loop-Proof           │
    ├──────────┬──────────┬──────────┬───────────────────────┤
    │ OBSERVE  │  ORIENT  │  DECIDE  │  ACT                  │
    ├──────────┴──────────┴──────────┴───────────────────────┤
    │  Agents : PHOTNX·SENTINEL·TRUTCH·CIBA·ARCHON·PATHFNDR  │
    │  Oakland: {"ACTIVE " if mcp_ready else "OFFLINE"}  TDD: ON  Loop-Guard: ON            │
    └────────────────────────────────────────────────────────┘
    Wellton Photonics — Mill Creek Lab WA · Phoenix AZ{RS}
""")
    print(f" [{GR}*{RS}] OODA cycle active on every prompt.")
    print(f" [{GR}*{RS}] TDD gates block placeholder writes.")
    print(f" [{GR}*{RS}] NDGi session graph tracks all file state.")
    print(f" [{GR}*{RS}] Commands: help · status · graph · history · clear · exit")
    print("-" * 67 + "\n")

HELP_TEXT = f"""
{CY}AEGIS v3.0 — COMMAND REFERENCE{RS}

{GR}Conversational:{RS}
  Any question              → plain English answer
  What time is it?          → local clock (instant, no engine)

{GR}File tasks:{RS}
  Create [component] for... → OODA checks → engine writes file
  Fix /path/to/file.py      → OODA checks existence → engine patches
  Add 'force' keyword       → overwrite even if NDGi says done

{GR}Shell (local, instant):{RS}
  ls  cat  cp  mv  mkdir  rm  git  python3  npm  pip

{GR}Built-in commands:{RS}
  status    BitNet + NDGi health check
  graph     NDGi session graph (what's done/pending/failed)
  history   Session turn history
  clear     Redraw splash
  help      This reference
  exit      End session

{GR}OODA cycle (automatic on every prompt):{RS}
  OBSERVE → scans files mentioned, checks existence + NDGi state
  ORIENT  → classifies intent, detects already-done + stuck files
  DECIDE  → blocks if done, warns if stuck 3×, routes to engine
  ACT     → TDD pre-check → write → TDD post-verify → NDGi register

{GR}TDD gates (block bad writes):{RS}
  ✗ Empty file
  ✗ "content goes here" placeholder
  ✗ Missing export in JS/JSX
  ✗ Brace mismatch in JS/JSX
  ✗ No function/class in .py
"""

def show_status(ndgi):
    import socket
    def chk(port):
        try:
            socket.create_connection(("localhost", port), timeout=1).close()
            return True
        except: return False
    print(f"\n{CY}[Status]{RS}")
    bn = chk(8080)
    nd = chk(8000)
    print(f"  BitNet b1.58  {'  '+GR+'ONLINE'+RS if bn else '  '+RD+'OFFLINE'+RS}  :8080")
    if not bn:
        print(f"  {YL}→ cd ~/BitNet && ./llama-server -m models/ggml-model-i2_s.gguf --port 8080{RS}")
    print(f"  NDGi proxy    {'  '+GR+'ONLINE'+RS if nd else '  '+YL+'OFFLINE'+RS}  :8000")
    if not nd:
        print(f"  {YL}→ cd ~/workspace/aegis-ternary/ndgi_proxy && uvicorn src.ndgi_proxy.main:app --port 8000{RS}")
    print(f"  Workspace     {WORKSPACE_ROOT}")
    done, pend, fail = ndgi.summary()
    print(f"  NDGi graph    {GR}{len(done)} done{RS}  {YL}{len(pend)} pending{RS}  {RD}{len(fail)} failed{RS}\n")

SHELL_CMDS = ('cp ','mv ','mkdir ','rm ','touch ','chmod ',
              'echo ','git ','python3 ','pip ','npm ','cd ','cat ')

def handle_local(cmd, mcp_agent, ndgi, ooda):
    c  = cmd.strip()
    cl = c.lower()
    if cl in ('exit','quit','q'):         return "exit"
    if cl == 'help':                       print(HELP_TEXT); return "handled"
    if cl == 'clear':                      return "clear"
    if cl == 'status':                     show_status(ndgi); return "handled"
    if cl in ('graph','ndgi','ndgi graph','show graph'):
        ndgi.print_graph(); return "handled"
    if cl == 'history':                    return "history"
    if any(cl.startswith(t) for t in
           ('what time','time is it')):
        print(f"\n{BL}[Local]{RS} {time.strftime('%A %B %d, %Y · %I:%M:%S %p')}\n")
        return "handled"
    if cl.startswith('ls') or cl.startswith('cat '):
        parts = c.split(None, 1)
        path  = resolve_path(parts[1]) if len(parts) > 1 else '.'
        try:
            if cl.startswith('ls'):
                print("\n" + "\n".join(sorted(os.listdir(path))) + "\n")
            else:
                print(f"\n{DM}" + open(path).read() + f"{RS}\n")
        except Exception as e:
            print(f"{RD}[Error]{RS} {e}\n")
        return "handled"
    if any(cl.startswith(p) for p in SHELL_CMDS):
        res = subprocess.run(c, shell=True, text=True, capture_output=True)
        if res.stdout: print(res.stdout)
        if res.stderr: print(f"{RD}{res.stderr}{RS}")
        return "handled"
    if mcp_agent:
        try:
            corrected = mcp_agent.correct_typos(c)
            if corrected and corrected != c:
                print(f"{DM}[Corrected: {corrected}]{RS}")
                return corrected
        except: pass
    return None

def _log(user, response):
    try:
        os.makedirs(LOG_DIR, exist_ok=True)
        ts = time.strftime("%Y%m%d_%H%M%S")
        open(os.path.join(LOG_DIR, f"{ts}.md"), "w").write(
            f"# {ts}\n\n**User:** {user}\n\n**Aegis:** {response[:2000]}\n")
    except: pass

# ══════════════════════════════════════════════════════════════════════════════
# MAIN
# ══════════════════════════════════════════════════════════════════════════════
def main():
    system    = load_system_prompt()
    mcp_agent = load_mcp_agent()
    ndgi      = NDGiSession()
    ooda      = OODAEngine(ndgi)
    display_splash(mcp_agent is not None)

    history: list = []

    while True:
        try:
            raw = input(f"{GR}jsosa@Aegis-Orchestrator:{RS}~$ ").strip()
            if not raw: continue

            result = handle_local(raw, mcp_agent, ndgi, ooda)

            if result == "exit":
                print(f"\n{DM}[Aegis] Session closed. TRIT_POS.{RS}\n")
                break
            if result == "clear":
                display_splash(mcp_agent is not None); continue
            if result == "history":
                for i,t in enumerate(history,1):
                    print(f"\n{DM}[{i}] You:{RS}  {t['user'][:80]}")
                    print(f"{DM}    Aegis:{RS} {t['assistant'][:120]}...")
                print(); continue
            if result == "handled": continue

            prompt = result if result else raw

            # ── OODA pre-flight ───────────────────────────────────────────────
            ctx = ooda.observe(prompt)
            ctx = ooda.orient(ctx)
            ctx = ooda.decide(ctx)
            pre = ooda.pre_act_report(ctx)

            if pre:
                print(pre)

            if ctx["action"] in ("skip","engine_offline"):
                continue

            # ── Engine ────────────────────────────────────────────────────────
            response = query_engine(system, history, prompt, ndgi, ooda)

            if response:
                history.append({"user": prompt, "assistant": response})
                if len(history) > MAX_HISTORY_TURNS:
                    history = history[-MAX_HISTORY_TURNS:]
                if mcp_agent:
                    try:
                        ro = mcp_agent.process_query(prompt)
                        if ro.suggestions:
                            print(f"{DM}Suggestions: "
                                  f"{', '.join(ro.suggestions[:3])}{RS}")
                    except: pass

        except KeyboardInterrupt:
            print(f"\n\n{YL}[Aegis] Ctrl+C caught. Type 'exit' to close.{RS}")

if __name__ == "__main__":
    main()
